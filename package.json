{
  "name": "new-skill",
  "version": "0.0.0",
  "description": "Interactive CLI to scaffold new skills",
  "type": "module",
  "author": "mateonunez <me@mateonunez.co>",
  "bin": {
    "new-skill": "./dist/new-skill"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/new-skill --sourcemap=external",
    "typecheck": "tsc --noEmit",
    "lint": "biome format && biome lint && biome check",
    "lint:fix": "biome format --write && biome lint --write --unsafe && biome check --write"
  },
  "dependencies": {
    "@opentui/core": "^0.1.86",
    "@opentui/react": "^0.1.86",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
